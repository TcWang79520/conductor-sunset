<!-- default log configuration -->
<Configuration status="WARN">
    <Appenders>
        <RollingFile name="RollingFile" fileName="/app/logs/server.log"
                     filePattern="/app/logs/server-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="%d{yyyy-MM-dd:HH:mm:ss.SSS} [%t] %-5p %c %x - %m%n" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10GB"/>
            </Policies>
            <Filter>
                <RegexFilter regex="(?i).*will NOT be atomic.*" onMatch="DENY" onMismatch="ACCEPT"/>
            </Filter>
            <DefaultRolloverStrategy max="14"></DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="RollingFile" />
        </Root>
    </Loggers>
</Configuration>
